# Production training uses real API-Football history only (set 1 only for tests)
WC_ALLOW_SYNTHETIC_TRAINING=false

# Override model directory (default: auto-prefer models/real_history/)
# WC_MODELS_DIR=models/real_history

APIFOOTBALL_KEY=your_api_football_key_here

# ── Kalshi trading (defaults: paper / dry-run only) ──
KALSHI_API_KEY_ID=
KALSHI_PRIVATE_KEY_PATH=
KALSHI_BASE_URL=https://api.elections.kalshi.com/trade-api/v2
KALSHI_DRY_RUN=true

# Live trading requires KALSHI_DRY_RUN=false AND ENABLE_LIVE_TRADING=true
ENABLE_LIVE_TRADING=false
AUTO_LIVE_TRADING=true
AUTO_PAPER_TRADING=true
REQUIRE_MANUAL_APPROVAL=false
KILL_SWITCH=false

# ── Edge & entry filters ──
MIN_EDGE_PREMATCH=0.08
MIN_EDGE_LIVE=0.10
MIN_CONFIDENCE=0.60
MIN_CONFIDENCE_LIVE=0.40
MAX_SPREAD_CENTS=6
MIN_LIQUIDITY_CONTRACTS=20
MAX_SLIPPAGE_CENTS=2
STALE_PRICE_SECONDS=120
MIN_MAPPING_CONFIDENCE=0.60

# ── Bankroll & exposure (live sizing uses Kalshi balance when live) ──
BANKROLL=20
MAX_STAKE_PER_TRADE=2
MAX_EXPOSURE_PER_MATCH=4
MAX_TOTAL_EXPOSURE=10
MAX_DAILY_LOSS=5
MAX_TRADES_PER_MATCH=3
MAX_CONSECUTIVE_LOSSES=3
MAX_BANKROLL_PCT_PER_TRADE=0.10

# ── Kelly sizing ──
KELLY_BANKROLL_CAP=0.15
KELLY_CONFIDENCE_HIGH=0.80
KELLY_CONFIDENCE_MID=0.70
KELLY_FRACTION_HIGH=0.50
KELLY_FRACTION_MID=0.35
KELLY_FRACTION_LOW=0.25

# ── Live entry guards ──
KALSHI_NEAR_SETTLED_HIGH=0.92
KALSHI_NEAR_SETTLED_LOW=0.08
MODEL_DISAGREE_CUTOFF=0.50
WIDE_GOAL_SPREAD_CENTS=50

# ── Paper trading (aggressive demo — live rules stay strict) ──
PAPER_AGGRESSIVE=true
PAPER_MIN_EDGE=0.02
PAPER_MIN_CONFIDENCE=0.45
PAPER_USE_MODEL_PRICING=true
PAPER_MODEL_DROP_EXIT=0.05
PAPER_EXIT_EDGE_REVERSAL=0.03
PAPER_TRADES_PER_MATCH=3
PAPER_CONTRACTS=1
PAPER_AGGRESSIVE_MIN_MODEL_PROB=0.52
PAPER_AGGRESSIVE_MIN_EDGE_FLOOR=0.03

# ── Scanner & market fetch ──
EXACT_SCORES_TO_SCAN=3
OPPORTUNITIES_CACHE_TTL_SECONDS=120
KALSHI_PREFETCH_MAPPING_CONFIDENCE=0.95
ADVANCE_CONFIDENCE_BLEND_PREMATCH=0.88
ADVANCE_CONFIDENCE_FLOOR=0.52
LIVE_MATCH_MINUTES=90
LIVE_POLL_INTERVAL_SECONDS=3
KALSHI_PRICE_FETCH_DELAY_SECONDS=0.08
LIVE_TIME_REMAINING_WARN_MINUTES=5

# DISPLAY_TIMEZONE=America/New_York
